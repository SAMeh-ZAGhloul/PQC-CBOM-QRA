# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=development            # development | production
APP_VERSION=1.0.0-mvp
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cbom
POSTGRES_USER=cbom
# POSTGRES_PASSWORD → Docker secret: ./secrets/db_password.txt

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD → Docker secret: ./secrets/redis_password.txt

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_USER=cbom
# RABBITMQ_PASSWORD → Docker secret: ./secrets/rabbitmq_password.txt

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false
MINIO_USER=cbomadmin
# MINIO_PASSWORD → Docker secret: ./secrets/minio_password.txt
MINIO_BUCKET_CBOM_EXPORTS=cbom-exports
MINIO_BUCKET_ZEEK_LOGS=zeek-logs
MINIO_BUCKET_SCAN_ARTIFACTS=scan-artifacts
MINIO_BUCKET_COMPLIANCE=compliance-packages

# ── Ollama SLM ───────────────────────────────────────────────────────────────
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=gemma2:2b
OLLAMA_MAX_CONCURRENT=10
OLLAMA_TIMEOUT_SECONDS=60

# ── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# JWT_PRIVATE_KEY_FILE → Docker secret: ./secrets/jwt_private_key.pem
# JWT_PUBLIC_KEY_FILE → Docker secret: ./secrets/jwt_public_key.pem

# ── Magika ──────────────────────────────────────────────────────────────────
MAGIKA_SERVICE_URL=http://worker-magika:8002
MAGIKA_CONFIDENCE_THRESHOLD=0.6

# ── Zeek ────────────────────────────────────────────────────────────────────
ZEEK_LOG_DIR=/app/zeek-logs
ZEEK_INTERFACE=eth0

# ── QARS Defaults ────────────────────────────────────────────────────────────
QARS_DEFAULT_Q_DAY_YEAR=2030
QARS_DEFAULT_SECTOR=general_enterprise

# ── Traffic Sim ──────────────────────────────────────────────────────────────
TRAFFIC_WEB_TARGET=https://traefik:443
TRAFFIC_SSH_HOST=sample-ssh
TRAFFIC_SSH_PORT=2222
TRAFFIC_DB_HOST=sample-db
TRAFFIC_DB_PORT=5432

# ── Backup ──────────────────────────────────────────────────────────────────
BACKUP_CRON_SCHEDULE=0 2 * * *    # 02:00 UTC daily
BACKUP_RETENTION_DAYS=90
